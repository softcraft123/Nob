<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:padding="24dp" android:layout_width="match_parent" android:layout_height="match_parent">
    <com.google.android.material.card.MaterialCardView android:id="@+id/resourceCard" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginTop="32dp" app:cardBackgroundColor="@color/primary_tint" app:cardCornerRadius="16dp" app:cardElevation="8dp" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toTopOf="0" app:strokeColor="@color/secondary_tint" app:strokeWidth="1dp">
        <androidx.constraintlayout.widget.ConstraintLayout android:padding="20dp" android:layout_width="match_parent" android:layout_height="wrap_content">
            <TextView android:textSize="12sp" android:textColor="@color/text_tint" android:id="@+id/resourceLabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="RESOURCE USAGE" android:letterSpacing="0.05" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toTopOf="0"/>
            <TextView android:textSize="20sp" android:textStyle="bold" android:textColor="@color/white" android:id="@+id/ramValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="RAM: 4.2GB / 8GB" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/resourceLabel"/>
            <ProgressBar android:id="@+id/ramProgress" android:layout_width="48dp" android:layout_height="48dp" android:max="100" android:progress="52" android:indeterminate="false" android:progressDrawable="@drawable/circular_progress_green" app:layout_constraintEnd_toEndOf="0" app:layout_constraintTop_toTopOf="0" style="?android:attr/progressBarStyleHorizontal"/>
            <com.google.android.material.card.MaterialCardView android:id="@+id/consoleCard" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginTop="16dp" app:cardBackgroundColor="@color/dark_primary" app:cardCornerRadius="8dp" app:cardElevation="0dp" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/ramValue">
                <LinearLayout android:orientation="vertical" android:padding="12dp" android:layout_width="match_parent" android:layout_height="wrap_content">
                    <LinearLayout android:gravity="center_vertical" android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content">
                        <View android:background="@drawable/dot_red" android:layout_width="8dp" android:layout_height="8dp"/>
                        <View android:background="@drawable/dot_yellow" android:layout_width="8dp" android:layout_height="8dp" android:layout_marginStart="4dp"/>
                        <View android:background="@drawable/dot_green" android:layout_width="8dp" android:layout_height="8dp" android:layout_marginStart="4dp"/>
                        <TextView android:textSize="12sp" android:textColor="@color/text_tint" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="console.log" android:layout_marginStart="12dp"/>
                    </LinearLayout>
                    <TextView android:textSize="11sp" android:textColor="@color/text_tint" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="[14:22:05] [Server thread/INFO]: Starting minecraft server...\10[14:22:12] [Server thread/INFO]: Preparing level &quot;world&quot;" android:lineSpacingExtra="6dp" android:fontFamily="monospace"/>
                    <TextView android:textSize="11sp" android:textColor="@color/primary_accent" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="[14:22:18] [User Authenticator/INFO]:\10Player Steve joined" android:fontFamily="monospace"/>
                    <TextView android:textSize="11sp" android:textColor="@color/text_tint" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="[14:22:20] [Server thread/INFO]: Done\10(12.4s)! For help, type &quot;help&quot;" android:lineSpacingExtra="6dp" android:fontFamily="monospace"/>
                    <LinearLayout android:gravity="center_vertical" android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp">
                        <TextView android:textSize="14sp" android:textStyle="bold" android:textColor="@color/primary_accent" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="&gt;"/>
                        <View android:background="@color/primary_accent" android:layout_width="8dp" android:layout_height="14dp" android:layout_marginStart="4dp"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
            <com.google.android.material.card.MaterialCardView android:id="@+id/propertiesButton" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginTop="12dp" app:cardBackgroundColor="@color/dark_primary" app:cardCornerRadius="8dp" app:cardElevation="0dp" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/consoleCard"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>
    <TextView android:textSize="26sp" android:textStyle="bold" android:textColor="@color/white" android:gravity="center" android:id="@+id/titleText" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginTop="48dp" android:text="Powerful Management" android:fontFamily="@font/space_grotesk_regular" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/resourceCard"/>
    <TextView android:textSize="16sp" android:textColor="@color/text_tint" android:gravity="center" android:id="@+id/descriptionText" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="Manage RAM, edit server.properties, and monitor live console logs in real-time." android:lineSpacingExtra="4dp" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/titleText"/>
</androidx.constraintlayout.widget.ConstraintLayout>
