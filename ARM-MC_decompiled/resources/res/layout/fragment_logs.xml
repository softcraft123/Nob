<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:background="@color/background_dark" android:layout_width="match_parent" android:layout_height="match_parent">
    <LinearLayout android:orientation="vertical" android:id="@+id/liveOutputHeader" android:layout_width="match_parent" android:layout_height="wrap_content" app:layout_constraintTop_toTopOf="0">
        <View android:background="@color/white" android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginBottom="8dp" android:alpha="0.3"/>
        <TextView android:textSize="12sp" android:textStyle="bold" android:textColor="#c5e1a5" android:layout_gravity="center_horizontal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-- LIVE OUTPUT --" android:letterSpacing="0.1"/>
        <View android:background="@drawable/dashed_line" android:layout_width="match_parent" android:layout_height="2dp" android:layout_marginTop="8dp" android:alpha="0.3" android:layerType="software"/>
    </LinearLayout>
    <HorizontalScrollView android:id="@+id/commandChipsScroll" android:background="#0d190d" android:paddingTop="8dp" android:paddingBottom="6dp" android:scrollbars="none" android:layout_width="0dp" android:layout_height="wrap_content" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/liveOutputHeader">
        <LinearLayout android:gravity="center_vertical" android:orientation="horizontal" android:id="@+id/commandChipsContainer" android:layout_width="wrap_content" android:layout_height="wrap_content" android:paddingStart="6dp"/>
    </HorizontalScrollView>
    <View android:id="@+id/chipsDivider" android:background="@color/white" android:layout_width="match_parent" android:layout_height="1dp" android:alpha="0.15" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/commandChipsScroll"/>
    <androidx.recyclerview.widget.RecyclerView android:id="@+id/logsRecyclerView" android:padding="8dp" android:clipToPadding="false" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintBottom_toTopOf="@+id/commandInputLayout" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/chipsDivider"/>
    <LinearLayout android:orientation="horizontal" android:id="@+id/commandInputLayout" android:background="@drawable/command_input_background" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" android:elevation="4dp" android:layout_marginHorizontal="12dp" android:paddingHorizontal="12dp" android:paddingVertical="8dp" app:layout_constraintBottom_toBottomOf="0" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0">
        <TextView android:textSize="18sp" android:textStyle="bold" android:textColor="#81c784" android:layout_gravity="center_vertical" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="/" android:paddingEnd="4dp"/>
        <EditText android:textSize="15sp" android:textColor="@color/white" android:textColorHint="#666666" android:layout_gravity="center_vertical" android:id="@+id/commandInput" android:background="@android:color/transparent" android:layout_width="0dp" android:layout_height="44dp" android:hint="Enter command..." android:singleLine="true" android:layout_weight="1" android:inputType="text" android:imeOptions="actionSend" android:paddingStart="4dp"/>
        <ImageButton android:layout_gravity="center_vertical" android:id="@+id/sendCommandButton" android:background="?attr/selectableItemBackgroundBorderless" android:layout_width="44dp" android:layout_height="44dp" android:src="@android:drawable/ic_menu_send" android:contentDescription="Send command" app:tint="#81c784"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
