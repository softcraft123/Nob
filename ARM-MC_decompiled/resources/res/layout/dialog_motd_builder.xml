<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:background="@color/background_dark" android:focusable="true" android:focusableInTouchMode="true" android:clickable="true" android:layout_width="match_parent" android:layout_height="wrap_content">
    <LinearLayout android:orientation="vertical" android:padding="20dp" android:layout_width="match_parent" android:layout_height="wrap_content">
        <View android:layout_gravity="center_horizontal" android:id="@+id/handleBar" android:background="@drawable/bottom_sheet_handle" android:layout_width="40dp" android:layout_height="4dp" android:layout_marginBottom="16dp"/>
        <TextView android:textSize="20sp" android:textStyle="bold" android:textColor="@color/white" android:layout_gravity="center_horizontal" android:id="@+id/titleText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="MOTD Builder"/>
        <TextView android:textSize="14sp" android:textColor="@color/text_tint" android:layout_gravity="center_horizontal" android:id="@+id/subtitleText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Create a styled server description"/>
        <com.google.android.material.card.MaterialCardView android:id="@+id/previewCard" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="20dp" app:cardBackgroundColor="@color/dark_primary" app:cardCornerRadius="12dp" app:cardElevation="0dp" app:strokeColor="@color/secondary_tint" app:strokeWidth="1dp">
            <LinearLayout android:orientation="vertical" android:padding="16dp" android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView android:textSize="10sp" android:textStyle="bold" android:textColor="@color/tertiary_tint" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="8dp" android:text="PREVIEW" android:letterSpacing="0.1"/>
                <TextView android:textSize="16sp" android:textColor="@color/white" android:gravity="center" android:id="@+id/motdPreview" android:background="@color/dark_primary" android:layout_width="match_parent" android:layout_height="wrap_content" android:minHeight="48dp" android:text="A Minecraft Server" android:fontFamily="monospace"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
        <TextView android:textSize="12sp" android:textStyle="bold" android:textColor="@color/white" android:id="@+id/colorsLabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="COLORS" android:letterSpacing="0.1"/>
        <HorizontalScrollView android:id="@+id/colorsScrollView" android:scrollbars="none" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp">
            <LinearLayout android:orientation="horizontal" android:id="@+id/colorsContainer" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </HorizontalScrollView>
        <TextView android:textSize="12sp" android:textStyle="bold" android:textColor="@color/white" android:id="@+id/stylesLabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="STYLES" android:letterSpacing="0.1"/>
        <HorizontalScrollView android:id="@+id/stylesScrollView" android:scrollbars="none" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp">
            <LinearLayout android:orientation="horizontal" android:id="@+id/stylesContainer" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </HorizontalScrollView>
        <EditText android:textSize="14sp" android:textColor="@color/white" android:textColorHint="@color/tertiary_tint" android:gravity="top|left|center_vertical|center_horizontal|center|start" android:id="@+id/motdEditText" android:background="@drawable/input_background" android:padding="16dp" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:hint="Enter your MOTD text..." android:maxLines="2" android:minLines="2" android:maxLength="59" android:inputType="textMultiLine" android:imeOptions="actionDone" android:fontFamily="monospace"/>
        <TextView android:textSize="12sp" android:textColor="@color/tertiary_tint" android:layout_gravity="end" android:id="@+id/charCountText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="0/59"/>
        <LinearLayout android:orientation="horizontal" android:id="@+id/buttonsContainer" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="24dp">
            <Button android:textSize="14sp" android:textColor="@color/white" android:id="@+id/cancelButton" android:layout_width="0dp" android:layout_height="48dp" android:text="Cancel" android:layout_weight="1" android:textAllCaps="false" android:layout_marginEnd="8dp" android:backgroundTint="@color/secondary_tint" app:cornerRadius="12dp"/>
            <Button android:textSize="14sp" android:textStyle="bold" android:textColor="@color/dark_primary" android:id="@+id/applyButton" android:layout_width="0dp" android:layout_height="48dp" android:text="Apply" android:layout_weight="1" android:textAllCaps="false" android:backgroundTint="@color/primary_accent" app:cornerRadius="12dp"/>
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
