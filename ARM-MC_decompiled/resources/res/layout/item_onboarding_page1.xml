<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:padding="24dp" android:layout_width="match_parent" android:layout_height="match_parent">
    <com.google.android.material.card.MaterialCardView android:id="@+id/serverCard" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginTop="32dp" app:cardBackgroundColor="@color/primary_tint" app:cardCornerRadius="16dp" app:cardElevation="8dp" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toTopOf="0" app:strokeColor="@color/secondary_tint" app:strokeWidth="1dp">
        <androidx.constraintlayout.widget.ConstraintLayout android:padding="20dp" android:layout_width="match_parent" android:layout_height="wrap_content">
            <ImageView android:id="@+id/serverIcon" android:layout_width="48dp" android:layout_height="48dp" android:src="@drawable/ic_server" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toTopOf="0" app:tint="@color/primary_accent"/>
            <TextView android:textSize="18sp" android:textStyle="bold" android:textColor="@color/white" android:id="@+id/serverName" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Survival World" android:layout_marginStart="12dp" app:layout_constraintStart_toEndOf="@+id/serverIcon" app:layout_constraintTop_toTopOf="@+id/serverIcon"/>
            <TextView android:textSize="12sp" android:textColor="@color/text_tint" android:id="@+id/serverVersion" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="v1.21.1 • PumpkinMC" android:layout_marginStart="12dp" app:layout_constraintStart_toEndOf="@+id/serverIcon" app:layout_constraintTop_toBottomOf="@+id/serverName"/>
            <View android:id="@+id/onlineIndicator" android:background="@drawable/status_indicator_online" android:layout_width="8dp" android:layout_height="8dp" app:layout_constraintEnd_toEndOf="0" app:layout_constraintTop_toTopOf="@+id/serverIcon"/>
            <View android:id="@+id/divider1" android:background="@color/secondary_tint" android:layout_width="0dp" android:layout_height="1dp" android:layout_marginTop="16dp" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/serverIcon"/>
            <TextView android:textSize="14sp" android:textColor="@color/text_tint" android:id="@+id/statusLabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="Status" android:drawablePadding="8dp" android:drawableStart="@drawable/status_indicator_online" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/divider1"/>
            <TextView android:textSize="14sp" android:textStyle="bold" android:textColor="@color/primary_accent" android:id="@+id/statusValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ONLINE" app:layout_constraintEnd_toEndOf="0" app:layout_constraintTop_toTopOf="@+id/statusLabel"/>
            <View android:id="@+id/divider2" android:background="@color/secondary_tint" android:layout_width="0dp" android:layout_height="1dp" android:layout_marginTop="16dp" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/statusLabel"/>
            <TextView android:textSize="14sp" android:textColor="@color/text_tint" android:id="@+id/playersLabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="Players" android:drawablePadding="8dp" android:drawableStart="@drawable/ic_person" android:drawableTint="@color/text_tint" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/divider2"/>
            <TextView android:textSize="14sp" android:textStyle="bold" android:textColor="@color/white" android:id="@+id/playersValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0 / 20" app:layout_constraintEnd_toEndOf="0" app:layout_constraintTop_toTopOf="@+id/playersLabel"/>
            <View android:id="@+id/divider3" android:background="@color/secondary_tint" android:layout_width="0dp" android:layout_height="1dp" android:layout_marginTop="16dp" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/playersLabel"/>
            <TextView android:textSize="12sp" android:textColor="@color/text_tint" android:id="@+id/cpuLabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="CPU USAGE" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/divider3"/>
            <TextView android:textSize="14sp" android:textStyle="bold" android:textColor="@color/white" android:id="@+id/cpuValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="12%" app:layout_constraintEnd_toEndOf="0" app:layout_constraintTop_toTopOf="@+id/cpuLabel"/>
            <ProgressBar android:id="@+id/cpuProgress" android:layout_width="0dp" android:layout_height="6dp" android:layout_marginTop="8dp" android:layout_marginBottom="8dp" android:max="100" android:progress="12" android:progressDrawable="@drawable/progress_bar_green" app:layout_constraintBottom_toBottomOf="0" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/cpuLabel" style="@style/Widget.AppCompat.ProgressBar.Horizontal"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>
    <TextView android:textSize="26sp" android:textStyle="bold" android:textColor="@color/white" android:gravity="center" android:id="@+id/titleText" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginTop="48dp" android:text="Minecraft Server Hosting\10Locally On Your Phone" android:lineSpacingExtra="4dp" android:fontFamily="@font/space_grotesk_regular" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/serverCard"/>
    <TextView android:textSize="16sp" android:textColor="@color/text_tint" android:gravity="center" android:id="@+id/descriptionText" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="Turn your Android device into a Minecraft server with just a few taps. No external hardware required." android:lineSpacingExtra="4dp" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/titleText"/>
</androidx.constraintlayout.widget.ConstraintLayout>
