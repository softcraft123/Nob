<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:background="@color/dark_primary" android:layout_width="match_parent" android:layout_height="match_parent" android:fillViewport="true">
    <androidx.constraintlayout.widget.ConstraintLayout android:padding="20dp" android:layout_width="match_parent" android:layout_height="wrap_content">
        <FrameLayout android:id="@+id/avatarContainer" android:layout_width="120dp" android:layout_height="120dp" android:layout_marginTop="16dp" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toTopOf="0">
            <com.google.android.material.imageview.ShapeableImageView android:id="@+id/profileAvatar" android:background="@color/primary_tint" android:layout_width="120dp" android:layout_height="120dp" android:src="@drawable/ic_person" android:scaleType="centerCrop" app:shapeAppearanceOverlay="@style/CircularImageView"/>
        </FrameLayout>
        <TextView android:textSize="20sp" android:textStyle="bold" android:textColor="@color/white" android:id="@+id/userEmail" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:fontFamily="@font/space_grotesk_regular" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/avatarContainer"/>
        <TextView android:textSize="14sp" android:textColor="@color/primary_accent" android:id="@+id/userRole" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/userEmail"/>
        <androidx.constraintlayout.widget.ConstraintLayout android:id="@+id/publicDomainBenefitCard" android:background="@drawable/bg_profile_card" android:padding="16dp" android:visibility="gone" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginTop="24dp" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/userRole">
            <TextView android:textSize="10sp" android:textStyle="bold" android:textColor="@color/primary_accent" android:id="@+id/benefitLabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="WHY CREATE AN ACCOUNT?" android:letterSpacing="0.1" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toTopOf="0"/>
            <ImageView android:id="@+id/benefitIcon" android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_globe" android:contentDescription="Public domain" app:layout_constraintEnd_toEndOf="0" app:layout_constraintTop_toTopOf="0" app:tint="@color/primary_accent"/>
            <TextView android:textSize="18sp" android:textStyle="bold" android:textColor="@color/white" android:id="@+id/benefitTitle" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Get a Public Domain" android:layout_marginEnd="48dp" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/benefitLabel"/>
            <TextView android:textSize="14sp" android:textColor="@color/text_tint" android:id="@+id/benefitDescription" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Create an account to get a free public domain for your server. Allow friends outside your network to join without any port forwarding setup!" android:lineSpacingMultiplier="1.2" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/benefitTitle"/>
            <com.google.android.material.button.MaterialButton android:textSize="14sp" android:textStyle="bold" android:textColor="@color/dark_primary" android:id="@+id/signUpBenefitButton" android:layout_width="wrap_content" android:layout_height="40dp" android:layout_marginTop="16dp" android:text="Sign Up Now" app:backgroundTint="@color/primary_accent" app:cornerRadius="8dp" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/benefitDescription"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.constraintlayout.widget.ConstraintLayout android:id="@+id/accountStatusCard" android:background="@drawable/bg_profile_card" android:padding="16dp" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginTop="12dp" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/publicDomainBenefitCard">
            <TextView android:textSize="10sp" android:textStyle="bold" android:textColor="@color/gold" android:id="@+id/planTierLabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PLAN TIER" android:letterSpacing="0.1" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toTopOf="0"/>
            <TextView android:textSize="12sp" android:textStyle="bold" android:textColor="@color/white" android:id="@+id/tierBadge" android:background="@drawable/bg_tier_badge" android:paddingTop="8dp" android:paddingBottom="8dp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="FREE" android:paddingStart="16dp" android:paddingEnd="16dp" app:layout_constraintEnd_toEndOf="0" app:layout_constraintTop_toTopOf="0"/>
            <TextView android:textSize="18sp" android:textStyle="bold" android:textColor="@color/white" android:id="@+id/accountStatusTitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Account Status" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/planTierLabel"/>
            <LinearLayout android:orientation="horizontal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/accountStatusTitle">
                <LinearLayout android:gravity="center" android:orientation="horizontal" android:id="@+id/upgradeButton" android:background="@drawable/bg_upgrade_button" android:paddingTop="8dp" android:paddingBottom="8dp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:paddingStart="12dp" android:paddingEnd="12dp">
                    <ImageView android:layout_width="14dp" android:layout_height="14dp" android:src="@drawable/ic_heart" android:contentDescription="Upgrade"/>
                    <TextView android:textSize="12sp" android:textStyle="bold" android:textColor="@color/gold" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Upgrade" android:layout_marginStart="6dp"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.constraintlayout.widget.ConstraintLayout android:id="@+id/subdomainCard" android:background="@drawable/bg_supporter_card" android:padding="16dp" android:visibility="gone" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginTop="12dp" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/accountStatusCard">
            <TextView android:textSize="10sp" android:textStyle="bold" android:textColor="@color/gold" android:id="@+id/subdomainLabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SUPPORTER PERK" android:letterSpacing="0.1" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toTopOf="0"/>
            <ImageView android:id="@+id/subdomainIcon" android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_globe" android:contentDescription="Custom subdomain" app:layout_constraintEnd_toEndOf="0" app:layout_constraintTop_toTopOf="0" app:tint="@color/gold"/>
            <TextView android:textSize="18sp" android:textStyle="bold" android:textColor="@color/white" android:id="@+id/subdomainTitle" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Custom Subdomain" android:layout_marginEnd="48dp" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/subdomainLabel"/>
            <LinearLayout android:orientation="vertical" android:id="@+id/claimedSubdomainContainer" android:visibility="gone" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginTop="8dp" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/subdomainTitle">
                <TextView android:textSize="16sp" android:textStyle="bold" android:textColor="@color/primary_accent" android:id="@+id/claimedSubdomainText" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:textSize="12sp" android:textColor="@color/text_tint" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Your custom Minecraft server address"/>
            </LinearLayout>
            <LinearLayout android:orientation="vertical" android:id="@+id/unclaimedSubdomainContainer" android:visibility="gone" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginTop="8dp" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/subdomainTitle">
                <TextView android:textSize="13sp" android:textColor="@color/text_tint" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Claim your unique subdomain for a personalized server address!" android:lineSpacingMultiplier="1.2"/>
                <com.google.android.material.button.MaterialButton android:textSize="14sp" android:textStyle="bold" android:textColor="@color/dark_primary" android:id="@+id/claimSubdomainButton" android:layout_width="wrap_content" android:layout_height="40dp" android:layout_marginTop="12dp" android:text="Claim Subdomain" app:backgroundTint="@color/gold" app:cornerRadius="8dp" app:icon="@drawable/ic_add" app:iconGravity="2" app:iconTint="@color/dark_primary"/>
            </LinearLayout>
            <ProgressBar android:id="@+id/subdomainLoading" android:visibility="gone" android:layout_width="24dp" android:layout_height="24dp" android:layout_marginTop="12dp" android:indeterminateTint="@color/gold" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/subdomainTitle"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.constraintlayout.widget.ConstraintLayout android:id="@+id/authMethodCard" android:background="@drawable/bg_profile_card" android:padding="16dp" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginTop="12dp" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/subdomainCard">
            <TextView android:textSize="10sp" android:textStyle="bold" android:textColor="@color/primary_accent" android:id="@+id/methodLabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="METHOD" android:letterSpacing="0.1" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toTopOf="0"/>
            <ImageView android:id="@+id/authMethodIcon" android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_key" android:contentDescription="Auth method" app:layout_constraintEnd_toEndOf="0" app:layout_constraintTop_toTopOf="0"/>
            <TextView android:textSize="18sp" android:textStyle="bold" android:textColor="@color/white" android:id="@+id/authMethodTitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Authentication" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/methodLabel"/>
            <LinearLayout android:gravity="center_vertical" android:orientation="horizontal" android:id="@+id/authMethodInfo" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/authMethodTitle">
                <ImageView android:id="@+id/authProviderIcon" android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/ic_email" android:contentDescription="Provider" app:tint="@color/primary_accent"/>
                <TextView android:textSize="14sp" android:textColor="@color/white" android:id="@+id/authProviderText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp"/>
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.constraintlayout.widget.ConstraintLayout android:id="@+id/sessionLimitCard" android:background="@drawable/bg_profile_card" android:padding="16dp" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginTop="12dp" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/authMethodCard">
            <TextView android:textSize="10sp" android:textStyle="bold" android:textColor="@color/primary_accent" android:id="@+id/usageLabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="USAGE" android:letterSpacing="0.1" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toTopOf="0"/>
            <ImageView android:id="@+id/sessionIcon" android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_timer" android:contentDescription="Session" app:layout_constraintEnd_toEndOf="0" app:layout_constraintTop_toTopOf="0"/>
            <TextView android:textSize="18sp" android:textStyle="bold" android:textColor="@color/white" android:id="@+id/sessionLimitTitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Domain Session Limit" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/usageLabel"/>
            <TextView android:textSize="12sp" android:textColor="@color/text_tint" android:id="@+id/sessionLimitDescription" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="2hr limit per session for free users" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/sessionLimitTitle"/>
            <ProgressBar android:id="@+id/sessionProgressBar" android:layout_width="0dp" android:layout_height="8dp" android:layout_marginTop="12dp" android:max="100" android:progress="100" android:progressDrawable="@drawable/progress_bar_green" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/sessionLimitDescription" style="?android:attr/progressBarStyleHorizontal"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <com.google.android.material.button.MaterialButton android:textSize="16sp" android:textStyle="bold" android:textColor="@color/white" android:id="@+id/faqButton" android:layout_width="0dp" android:layout_height="56dp" android:layout_marginTop="32dp" android:text="FAQ &amp; Help" app:backgroundTint="@color/dark_primary" app:cornerRadius="12dp" app:icon="@drawable/ic_search" app:iconGravity="2" app:iconPadding="8dp" app:iconTint="@color/primary_accent" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/sessionLimitCard" app:strokeColor="@color/secondary_tint" app:strokeWidth="1dp"/>
        <com.google.android.material.button.MaterialButton android:textSize="16sp" android:textStyle="bold" android:textColor="@color/danger_dark" android:id="@+id/logoutButton" android:layout_width="0dp" android:layout_height="56dp" android:layout_marginTop="12dp" android:layout_marginBottom="24dp" android:text="Log Out" app:backgroundTint="@color/dark_primary" app:cornerRadius="12dp" app:icon="@drawable/ic_logout" app:iconGravity="2" app:iconPadding="8dp" app:iconTint="@color/danger_dark" app:layout_constraintBottom_toTopOf="@+id/versionText" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/faqButton" app:strokeColor="@color/danger_dark" app:strokeWidth="1dp"/>
        <TextView android:textSize="12sp" android:textColor="@color/tertiary_tint" android:id="@+id/versionText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="16dp" android:text="arm-mc.com v2.4.0-stable" app:layout_constraintBottom_toBottomOf="0" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
