<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:id="@+id/rootLayout" android:background="@color/dark_primary" android:padding="24dp" android:focusable="true" android:focusableInTouchMode="true" android:clickable="true" android:layout_width="match_parent" android:layout_height="match_parent">
    <ImageView android:id="@+id/backButton" android:padding="12dp" android:layout_width="48dp" android:layout_height="48dp" android:layout_marginTop="-8dp" android:src="@drawable/ic_arrow_back" android:contentDescription="Back" android:layout_marginStart="-12dp" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toTopOf="0" app:tint="@color/white"/>
    <ImageView android:id="@+id/logoText" android:layout_width="wrap_content" android:layout_height="16dp" android:layout_marginTop="24dp" android:src="@drawable/logo_text" android:scaleType="fitStart" android:adjustViewBounds="true" android:contentDescription="Logo" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/backButton"/>
    <TextView android:textSize="32sp" android:textStyle="bold" android:textColor="@color/white" android:id="@+id/titleText" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Create Account" android:fontFamily="@font/space_grotesk_regular" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/logoText"/>
    <TextView android:textSize="16sp" android:textColor="@color/text_tint" android:id="@+id/subtitleText" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Start your ARM-based Minecraft server in seconds." app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/titleText"/>
    <TextView android:textSize="12sp" android:textStyle="bold" android:textColor="@color/white" android:id="@+id/emailLabel" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginTop="32dp" android:text="EMAIL ADDRESS" android:letterSpacing="0.05" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/subtitleText"/>
    <EditText android:textSize="16sp" android:textColor="@color/white" android:textColorHint="@color/tertiary_tint" android:id="@+id/emailInput" android:background="@drawable/input_background" android:padding="16dp" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:hint="steve@craft.com" android:maxLines="1" android:drawablePadding="12dp" android:inputType="textEmailAddress" android:imeOptions="actionNext" android:drawableStart="@drawable/ic_email" android:drawableTint="@color/primary_accent" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/emailLabel"/>
    <TextView android:textSize="12sp" android:textStyle="bold" android:textColor="@color/white" android:id="@+id/passwordLabel" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:text="PASSWORD" android:letterSpacing="0.05" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/emailInput"/>
    <FrameLayout android:id="@+id/passwordContainer" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginTop="8dp" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/passwordLabel">
        <EditText android:textSize="16sp" android:textColor="@color/white" android:textColorHint="@color/tertiary_tint" android:id="@+id/passwordInput" android:background="@drawable/input_background" android:padding="16dp" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Min. 8 characters" android:maxLines="1" android:drawablePadding="12dp" android:inputType="textPassword" android:imeOptions="actionDone" android:drawableStart="@drawable/ic_shield" android:paddingEnd="48dp" android:drawableTint="@color/primary_accent"/>
        <ImageView android:layout_gravity="right|center_vertical|center_horizontal|center|end" android:id="@+id/passwordToggle" android:padding="12dp" android:layout_width="48dp" android:layout_height="48dp" android:src="@drawable/ic_visibility" android:contentDescription="Toggle password visibility" app:tint="@color/primary_accent"/>
    </FrameLayout>
    <TextView android:textSize="14sp" android:textColor="@color/danger_dark" android:id="@+id/errorText" android:visibility="gone" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginTop="8dp" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/passwordContainer"/>
    <CheckBox android:textSize="14sp" android:textColor="@color/text_tint" android:id="@+id/tosCheckbox" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="I agree to the Terms of Service" android:buttonTint="@color/primary_accent" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/errorText"/>
    <com.google.android.material.button.MaterialButton android:textSize="16sp" android:textStyle="bold" android:textColor="@color/dark_primary" android:id="@+id/signUpButton" android:layout_width="0dp" android:layout_height="56dp" android:layout_marginTop="16dp" android:text="Sign Up" app:backgroundTint="@color/primary_accent" app:cornerRadius="12dp" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/tosCheckbox"/>
    <ProgressBar android:id="@+id/loadingProgress" android:visibility="gone" android:layout_width="24dp" android:layout_height="24dp" android:indeterminateTint="@color/dark_primary" app:layout_constraintBottom_toBottomOf="@+id/signUpButton" app:layout_constraintEnd_toEndOf="@+id/signUpButton" app:layout_constraintStart_toStartOf="@+id/signUpButton" app:layout_constraintTop_toTopOf="@+id/signUpButton"/>
    <LinearLayout android:gravity="center" android:orientation="horizontal" android:id="@+id/orDivider" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginTop="24dp" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/signUpButton">
        <View android:background="@color/secondary_tint" android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>
        <TextView android:textSize="14sp" android:textColor="@color/text_tint" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Or" android:layout_marginStart="16dp" android:layout_marginEnd="16dp"/>
        <View android:background="@color/secondary_tint" android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>
    </LinearLayout>
    <com.google.android.material.button.MaterialButton android:textSize="16sp" android:textStyle="bold" android:textColor="@color/white" android:id="@+id/continueGoogleButton" android:layout_width="0dp" android:layout_height="56dp" android:layout_marginTop="24dp" android:text="Continue with Google" app:backgroundTint="@color/primary_tint" app:cornerRadius="12dp" app:icon="@drawable/ic_google" app:iconGravity="2" app:iconPadding="12dp" app:iconTint="@null" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/orDivider" app:strokeColor="@color/secondary_tint" app:strokeWidth="1dp"/>
    <LinearLayout android:orientation="horizontal" android:id="@+id/loginContainer" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="24dp" android:layout_marginBottom="16dp" app:layout_constraintBottom_toTopOf="@+id/termsContainer" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/continueGoogleButton" app:layout_constraintVertical_bias="0">
        <TextView android:textSize="14sp" android:textColor="@color/text_tint" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Already have an account?  "/>
        <TextView android:textSize="14sp" android:textStyle="bold" android:textColor="@color/primary_accent" android:id="@+id/logInLink" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Log In"/>
    </LinearLayout>
    <LinearLayout android:orientation="horizontal" android:id="@+id/termsContainer" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="16dp" app:layout_constraintBottom_toBottomOf="0" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0">
        <TextView android:textSize="12sp" android:textColor="@color/text_tint" android:id="@+id/termsLink" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Terms of Service"/>
        <TextView android:textSize="12sp" android:textColor="@color/text_tint" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="·" android:layout_marginStart="16dp" android:layout_marginEnd="16dp"/>
        <TextView android:textSize="12sp" android:textColor="@color/text_tint" android:id="@+id/privacyLink" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Privacy Policy"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
