            <Button android:textSize="14sp" android:textStyle="bold" android:textColor="@color/primary_accent" android:id="@+id/selectTemplateButton" android:layout_width="match_parent" android:layout_height="65dp" android:text="Select Template" android:textAllCaps="false" android:fontFamily="@font/space_grotesk_regular" android:backgroundTint="@color/card_light" app:cornerRadius="16dp" app:strokeColor="@color/secondary_tint" app:strokeWidth="1dp" style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
        </LinearLayout>
    </FrameLayout>
</com.google.android.material.card.MaterialCardView>
