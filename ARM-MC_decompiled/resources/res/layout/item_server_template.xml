            <TextView android:textSize="20sp" android:textStyle="bold" android:textColor="@color/white" android:id="@+id/templateName" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="4dp" android:fontFamily="@font/space_grotesk_regular"/>
