<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:layout_width="match_parent" android:layout_height="match_parent">
    <com.google.android.material.appbar.AppBarLayout android:theme="@style/Theme.ArmMC.AppBarOverlay" android:id="@+id/appBarLayout" android:layout_width="match_parent" android:layout_height="wrap_content">
        <androidx.appcompat.widget.Toolbar android:gravity="center_vertical" android:id="@+id/toolbar" android:background="@color/background_dark" android:paddingTop="0dp" android:paddingBottom="0dp" android:layout_width="match_parent" android:layout_height="wrap_content" android:minHeight="80dp" android:paddingStart="25dp" android:paddingEnd="20dp" app:contentInsetStartWithNavigation="0dp" app:popupTheme="@style/Theme.ArmMC.PopupOverlay">
            <ImageView android:layout_gravity="left" android:id="@+id/toolbar_logo" android:paddingTop="5dp" android:visibility="gone" android:layout_width="120dp" android:layout_height="30dp" android:src="@drawable/logo_text" android:contentDescription="@string/app_name"/>
            <TextView android:textSize="20sp" android:textStyle="bold" android:textColor="@android:color/white" android:layout_gravity="left" android:id="@+id/toolbar_title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="My Servers" android:fontFamily="@font/space_grotesk_regular"/>
            <LinearLayout android:gravity="center_vertical" android:layout_gravity="right" android:orientation="horizontal" android:layout_width="wrap_content" android:layout_height="wrap_content">
                <LinearLayout android:gravity="center_vertical" android:orientation="horizontal" android:id="@+id/tunnelRegionButton" android:background="@drawable/tunnel_button_background" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="40dp" android:paddingStart="12dp" android:paddingEnd="10dp" android:layout_marginEnd="8dp">
                    <ImageView android:layout_width="15dp" android:layout_height="15dp" android:src="@drawable/ic_globe" android:contentDescription="Tunnel region" android:layout_marginEnd="6dp" app:tint="@color/primary"/>
                    <TextView android:textSize="13sp" android:textStyle="bold" android:textColor="@color/primary" android:id="@+id/tunnelRegionText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Region: EU" android:fontFamily="@font/space_grotesk_regular"/>
                    <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_arrow_down" android:contentDescription="Select region" android:layout_marginStart="2dp" app:tint="@color/primary"/>
                </LinearLayout>
                <com.google.android.material.button.MaterialButton android:id="@+id/discordButton" android:padding="0dp" android:layout_width="50dp" android:layout_height="50dp" android:insetLeft="5dp" android:insetRight="5dp" android:insetTop="5dp" android:insetBottom="5dp" android:contentDescription="Join our Discord" app:backgroundTint="@color/white_accent_50" app:cornerRadius="12dp" app:icon="@drawable/ic_discord" app:iconGravity="2" app:iconPadding="0dp" app:iconTint="@android:color/white"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/addServerButton" android:padding="0dp" android:visibility="gone" android:layout_width="50dp" android:layout_height="50dp" android:insetLeft="5dp" android:insetRight="5dp" android:insetTop="5dp" android:insetBottom="5dp" app:backgroundTint="@color/card_light" app:cornerRadius="12dp" app:icon="@drawable/ic_add" app:iconGravity="2" app:iconPadding="0dp" app:iconTint="@color/primary"/>
            </LinearLayout>
        </androidx.appcompat.widget.Toolbar>
        <View android:background="@color/primary_tint" android:layout_width="match_parent" android:layout_height="1dp"/>
    </com.google.android.material.appbar.AppBarLayout>
    <include layout="@layout/content_main"/>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
