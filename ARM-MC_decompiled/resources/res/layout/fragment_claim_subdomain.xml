<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:background="@color/dark_primary" android:layout_width="match_parent" android:layout_height="match_parent" android:fillViewport="true">
    <androidx.constraintlayout.widget.ConstraintLayout android:padding="24dp" android:layout_width="match_parent" android:layout_height="wrap_content">
        <ImageView android:id="@+id/headerIcon" android:layout_width="80dp" android:layout_height="80dp" android:layout_marginTop="24dp" android:src="@drawable/ic_globe" android:contentDescription="Custom Domain" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toTopOf="0" app:tint="@color/primary_accent"/>
        <TextView android:textSize="24sp" android:textStyle="bold" android:textColor="@color/white" android:id="@+id/title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="Claim Your Subdomain" android:fontFamily="@font/space_grotesk_regular" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/headerIcon"/>
        <TextView android:textSize="14sp" android:textColor="@color/text_tint" android:gravity="center" android:id="@+id/subtitle" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="As a Supporter, you can claim a custom subdomain for your Minecraft server!" android:lineSpacingMultiplier="1.3" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/title"/>
        <androidx.constraintlayout.widget.ConstraintLayout android:id="@+id/inputCard" android:background="@drawable/bg_profile_card" android:padding="20dp" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginTop="32dp" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/subtitle">
            <TextView android:textSize="10sp" android:textStyle="bold" android:textColor="@color/primary_accent" android:id="@+id/inputLabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="YOUR SUBDOMAIN" android:letterSpacing="0.1" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toTopOf="0"/>
            <LinearLayout android:gravity="center_vertical" android:orientation="horizontal" android:id="@+id/subdomainInputContainer" android:background="@drawable/bg_input_field" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:paddingStart="16dp" android:paddingEnd="16dp" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/inputLabel">
                <EditText android:textSize="18sp" android:textColor="@color/white" android:textColorHint="@color/text_tint" android:id="@+id/subdomainInput" android:background="@null" android:layout_width="0dp" android:layout_height="56dp" android:hint="myserver" android:maxLength="20" android:layout_weight="1" android:inputType="textNoSuggestions" android:importantForAutofill="2"/>
                <TextView android:textSize="16sp" android:textStyle="bold" android:textColor="@color/primary_accent" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=".arm-mc.com"/>
            </LinearLayout>
            <LinearLayout android:gravity="center_vertical" android:orientation="horizontal" android:id="@+id/availabilityStatus" android:visibility="gone" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginTop="8dp" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/subdomainInputContainer">
                <ImageView android:id="@+id/availabilityIcon" android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_check_circle" android:contentDescription="Status" app:tint="@color/primary_accent"/>
                <TextView android:textSize="13sp" android:id="@+id/availabilityText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp"/>
            </LinearLayout>
            <ProgressBar android:id="@+id/availabilityLoading" android:visibility="gone" android:layout_width="20dp" android:layout_height="20dp" android:layout_marginTop="12dp" android:indeterminateTint="@color/primary_accent" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/subdomainInputContainer"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.constraintlayout.widget.ConstraintLayout android:id="@+id/warningCard" android:background="@drawable/bg_warning_card" android:padding="16dp" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginTop="16dp" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/inputCard">
            <ImageView android:id="@+id/warningIcon" android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_warning" android:contentDescription="Warning" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toTopOf="0" app:tint="@color/warning_orange"/>
            <TextView android:textSize="14sp" android:textStyle="bold" android:textColor="@color/warning_orange" android:id="@+id/warningTitle" android:layout_width="0dp" android:layout_height="wrap_content" android:text="Important: This Cannot Be Changed" android:layout_marginStart="12dp" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toEndOf="@+id/warningIcon" app:layout_constraintTop_toTopOf="0"/>
            <TextView android:textSize="13sp" android:textColor="@color/text_tint" android:id="@+id/warningText" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Once you claim your subdomain, it cannot be changed. Choose carefully!" android:lineSpacingMultiplier="1.2" android:layout_marginStart="12dp" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toEndOf="@+id/warningIcon" app:layout_constraintTop_toBottomOf="@+id/warningTitle"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.constraintlayout.widget.ConstraintLayout android:id="@+id/dnsInfoCard" android:background="@drawable/bg_profile_card" android:padding="16dp" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginTop="12dp" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/warningCard">
            <ImageView android:id="@+id/dnsIcon" android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_clock" android:contentDescription="DNS Info" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toTopOf="0" app:tint="@color/primary_accent"/>
            <TextView android:textSize="14sp" android:textStyle="bold" android:textColor="@color/white" android:id="@+id/dnsTitle" android:layout_width="0dp" android:layout_height="wrap_content" android:text="DNS Propagation Time" android:layout_marginStart="12dp" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toEndOf="@+id/dnsIcon" app:layout_constraintTop_toTopOf="0"/>
            <TextView android:textSize="13sp" android:textColor="@color/text_tint" android:id="@+id/dnsText" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="After claiming your subdomain, it may take up to 24 hours for DNS changes to propagate worldwide. Your subdomain will work after this period." android:lineSpacingMultiplier="1.2" android:layout_marginStart="12dp" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toEndOf="@+id/dnsIcon" app:layout_constraintTop_toBottomOf="@+id/dnsTitle"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <com.google.android.material.button.MaterialButton android:enabled="false" android:textSize="16sp" android:textStyle="bold" android:textColor="@color/dark_primary" android:id="@+id/claimButton" android:layout_width="0dp" android:layout_height="56dp" android:layout_marginTop="24dp" android:text="Claim Subdomain" app:backgroundTint="@color/primary_accent" app:cornerRadius="12dp" app:icon="@drawable/ic_check_circle" app:iconGravity="2" app:iconTint="@color/dark_primary" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/dnsInfoCard"/>
        <ProgressBar android:id="@+id/loadingIndicator" android:visibility="gone" android:layout_width="48dp" android:layout_height="48dp" android:indeterminateTint="@color/primary_accent" app:layout_constraintBottom_toBottomOf="@+id/claimButton" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toTopOf="@+id/claimButton"/>
        <com.google.android.material.button.MaterialButton android:textColor="@color/text_tint" android:id="@+id/cancelButton" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Maybe Later" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/claimButton" style="@style/Widget.MaterialComponents.Button.TextButton"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
